# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # NEVER expose this publicly

# ─── App URL ─────────────────────────────────────────────────────────────────
# Must match your actual domain — used in email links, redirects, etc.
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your account password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=CPL <your_gmail@gmail.com>

# ─── Cron Job Security ───────────────────────────────────────────────────────
# Used to authenticate internal cron endpoints — keep this secret
# Generate with: openssl rand -base64 32
CRON_SECRET=your_random_secret_here

# ─── Docker / Traefik ────────────────────────────────────────────────────────
# Your actual domain (used in docker-compose Traefik labels)
DOMAIN=yourdomain.com
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=your@email.com

# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # NEVER expose this publicly

# ─── App URL ─────────────────────────────────────────────────────────────────
# Must match your actual domain — used in email links, redirects, etc.
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
# For Gmail: use an App Password (not your account password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=CPL <your_gmail@gmail.com>

# ─── Cron Job Security ───────────────────────────────────────────────────────
# Used to authenticate internal cron endpoints — keep this secret
# Generate with: openssl rand -base64 32
CRON_SECRET=your_random_secret_here

# ─── Docker / Traefik ────────────────────────────────────────────────────────
# Your actual domain (used in docker-compose Traefik labels)
DOMAIN=yourdomain.com
# Email for Let's Encrypt certificate notifications
ACME_EMAIL=your@email.com

# ─── Web Push / VAPID (Phase 8) ──────────────────────────────────────────────
# Required for push notifications. Generate a key pair once with:
#
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k,null,2))"
#
# Copy the output into the two variables below.
# The public key is exposed to the browser (NEXT_PUBLIC_*).
# The private key is server-only — NEVER commit it or expose it publicly.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── Email Unsubscribe (Phase 7) ─────────────────────────────────────────────
# No extra config needed — unsubscribe tokens are generated automatically by
# Supabase (gen_random_uuid()) when player rows are created (migration 013).
# The one-click unsubscribe URL format is:
#   ${NEXT_PUBLIC_APP_URL}/api/notifications/unsubscribe?token=<uuid>
# SMTP port 465 uses SSL/TLS; port 587 uses STARTTLS (recommended).
# SendGrid: SMTP_USER=apikey  SMTP_PASS=SG.xxxxxxxxxxxx  SMTP_HOST=smtp.sendgrid.net

############################################################
# Supabase Self-Hosted — Environment Variables
# Copy this to .env and fill in every value before starting
############################################################

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=your-strong-postgres-password-here
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# ── JWT (must be at least 32 characters) ────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-at-least-32-chars-long
JWT_EXPIRY=3600

# ── API Keys (generate with the helper below) ────────────────────────────────
# Run once to generate:
#   node -e "
#     const jwt = require('jsonwebtoken');
#     const secret = 'YOUR_JWT_SECRET';
#     const anon  = jwt.sign({ role: 'anon',         iss: 'supabase', iat: 1741388400, exp: 1898982000 }, secret);
#     const svc   = jwt.sign({ role: 'service_role', iss: 'supabase', iat: 1741388400, exp: 1898982000 }, secret);
#     console.log('ANON_KEY=', anon);
#     console.log('SERVICE_ROLE_KEY=', svc);
#   "
ANON_KEY=your-anon-jwt-here
SERVICE_ROLE_KEY=your-service-role-jwt-here

# ── Public URL ───────────────────────────────────────────────────────────────
# If you have a domain: https://supabase.yourdomain.com
# If using IP only (temporary): http://YOUR_SERVER_IP:8000
SUPABASE_PUBLIC_URL=http://YOUR_SERVER_IP:8000
API_EXTERNAL_URL=http://YOUR_SERVER_IP:8000

# ── Site URL (your Next.js app URL) ─────────────────────────────────────────
SITE_URL=http://YOUR_SERVER_IP:3000
ADDITIONAL_REDIRECT_URLS=

# ── Email (for auth emails: verification, password reset) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_SENDER_NAME=Chiniot Padel League
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_EMAIL_SIGNUP=true

# ── Studio dashboard ─────────────────────────────────────────────────────────
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=your-strong-dashboard-password
STUDIO_DEFAULT_ORGANIZATION=CPL
STUDIO_DEFAULT_PROJECT=Chiniot Padel League

# ── Realtime ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 64 | tr -d '\n'
SECRET_KEY_BASE=your-secret-key-base-64-chars-min

# ── Logflare (Analytics) ─────────────────────────────────────────────────────
LOGFLARE_API_KEY=your-logflare-key
